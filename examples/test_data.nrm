meta:
  name: "Binary Classification Test Dataset"
  created: "2024-12-27"
  description: "Test dataset for binary classification"

data:
  - input: [0.6, 0.7, 0.4]
    output: [1.0]
  - input: [0.1, 0.3, 0.2]
    output: [0.0]
  - input: [0.8, 0.9, 0.7]
    output: [1.0]

model_config:
  input_size: 3
  layers:
    - type: "dense"
      neurons: 64
      activation: "relu"
    - type: "dense"
      neurons: 1
      activation: "sigmoid" 